{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "#modules/*": ["modules/*"]
    }
  },
  "include": [
    "app.js",
    "onboarding.js",
    "modules/**/*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
