{
  "name": "pet-care-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "npm run lint && npm run typecheck && npm run content:audit && npm run snippet:audit && npm run schema:audit && npm run observability:audit && npm run sitekit:audit",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "content:audit": "node scripts/audit-content-quality.mjs",
    "snippet:audit": "node scripts/audit-search-snippets.mjs",
    "schema:audit": "node scripts/audit-structured-data.mjs",
    "observability:audit": "node scripts/audit-observability.mjs",
    "design:audit": "impeccable detect --fast src/app src/components",
    "review:check": "node scripts/verify-review-readiness.mjs",
    "sitekit:audit": "node scripts/audit-site-kit.mjs"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.4",
    "@types/mdx": "^2.0.13",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "impeccable": "^2.1.8",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
